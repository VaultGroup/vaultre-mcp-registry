{
  "mcp_servers": [
    {
      "name": "vaultre-mcp",
      "description": "VaultRE Atlassian integration (Jira, Confluence)",
      "homepage": "https://github.com/VaultGroup/vaultre-mcp",
      "documentation": "https://github.com/VaultGroup/vaultre-mcp/blob/main/README.md",
      "language": "Node.js",
      "url": "npx vaultre-mcp"
    },
    {
      "name": "atlassian-mcp",
      "description": "Official Atlassian Rovo (Remote) MCP server for Jira, Confluence and Compass",
      "homepage": "https://www.atlassian.com/platform/remote-mcp-server",
      "documentation": "https://support.atlassian.com/atlassian-rovo-mcp-server/docs/getting-started-with-the-atlassian-remote-mcp-server/",
      "language": "Node.js",
      "url": "npx -y mcp-remote@0.1.38 https://mcp.atlassian.com/v1/mcp/authv2"
    },
    {
      "name": "zendesk-mcp",
      "description": "Self-built read-only Zendesk MCP server (search + fetch tickets) for the vaultre-copilot-bot. Subdomain proptech-group; Basic email/token auth.",
      "homepage": "https://github.com/VaultGroup/vaultre-ai-box",
      "documentation": "https://github.com/VaultGroup/vaultre-ai-box/blob/main/zendesk-mcp.mjs",
      "language": "Node.js",
      "url": "node /app/zendesk-mcp.mjs"
    }
  ]
}
